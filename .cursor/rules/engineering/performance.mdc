# Cursor Rules: Performance Standards

rules:
  - id: performance.budgets.sla_requirements
    description: |
      Performance budgets and SLAs must be defined for all critical operations.
      - Health check endpoints must respond in <100ms
      - Simple read operations must complete in <500ms
      - Complex operations must complete in <5s or support async/streaming
      - Module operations should complete within reasonable time limits
      - Document performance expectations in module docstrings
      - Monitor and alert on SLA violations
    severity: error

  - id: performance.budgets.resource_limits
    description: |
      Resource usage limits must be enforced.
      - Set memory limits for module operations
      - Set CPU time limits for long-running operations
      - Set timeout limits for external service calls
      - Monitor resource usage and alert on excessive consumption
      - Implement resource cleanup for completed operations
      - Document resource requirements for each module
    severity: error

  - id: performance.optimization.caching
    description: |
      Caching must be used appropriately to improve performance.
      - Cache expensive computations and external API calls
      - Use appropriate cache invalidation strategies
      - Document cache TTL and invalidation policies
      - Monitor cache hit rates
      - Use thread-safe caching mechanisms
      - Consider cache size limits and eviction policies
    severity: warning

  - id: performance.optimization.lazy_loading
    description: |
      Lazy loading must be used for expensive resources.
      - Load models and heavy dependencies on-demand, not at import time
      - Use module `initialize()` method for delayed resource loading
      - Avoid loading unnecessary data or modules
      - Document lazy loading behavior in module docstrings
      - Test lazy loading behavior in tests
    severity: warning

  - id: performance.optimization.async_operations
    description: |
      Async operations should be used for I/O-bound tasks.
      - Use async/await for network requests and file I/O
      - Use async endpoints for long-running operations
      - Support streaming responses for large data transfers
      - Document async behavior and usage patterns
      - Test async operations properly
    severity: warning

  - id: performance.optimization.batching
    description: |
      Batching should be used for multiple similar operations.
      - Batch database queries when possible
      - Batch API calls to external services
      - Use batch operations for embeddings and processing
      - Document batch size limits and recommendations
      - Test batch operations with various batch sizes
    severity: warning

  - id: performance.measurement.timing
    description: |
      Performance-critical operations must include timing measurements.
      - Use MetricsCollector to track execution times
      - Measure operation-level and module-level performance
      - Track min/max/average execution times
      - Identify slow operations and optimize
      - Document expected performance characteristics
    severity: error

  - id: performance.measurement.profiling
    description: |
      Profiling should be used to identify performance bottlenecks.
      - Use profiling tools (cProfile, py-spy) for performance analysis
      - Profile critical paths and hot spots
      - Document profiling procedures and tools
      - Use profiling results to guide optimization efforts
      - Re-profile after optimizations to verify improvements
    severity: warning

  - id: performance.measurement.benchmarking
    description: |
      Performance benchmarks must be established and maintained.
      - Create benchmarks for critical operations
      - Run benchmarks as part of CI/CD pipeline
      - Track performance trends over time
      - Alert on performance regressions
      - Document benchmark procedures and expected results
    severity: warning

  - id: performance.quality.regression_prevention
    description: |
      Performance regressions must be prevented.
      - Monitor performance metrics in CI/CD
      - Set performance budgets and fail builds on violations
      - Review performance impact of code changes
      - Test performance-critical code paths
      - Document performance characteristics and changes
    severity: warning

  - id: performance.quality.resource_efficiency
    description: |
      Code must be resource-efficient.
      - Avoid unnecessary memory allocations
      - Use generators for large data processing
      - Clean up resources promptly (use context managers)
      - Avoid memory leaks and resource leaks
      - Monitor memory and CPU usage
    severity: error

examples:
  - description: "Performance measurement with metrics"
    language: python
    code: |
      import time
      from mavaia_core.brain.metrics import record_operation
      
      
      def execute_with_timing(module_name: str, operation: str, params: dict[str, Any]):
          """Execute operation with performance measurement"""
          start_time = time.time()
          success = True
          error = None
          
          try:
              result = perform_operation(operation, params)
              
              # Check performance budget
              execution_time = time.time() - start_time
              if execution_time > 5.0:  # 5 second budget
                  logger.warning(
                      f"Operation '{operation}' exceeded performance budget: {execution_time:.2f}s",
                      extra={"module": module_name, "operation": operation, "time": execution_time}
                  )
              
              return result
          except Exception as e:
              success = False
              error = str(e)
              raise
          finally:
              execution_time = time.time() - start_time
              record_operation(
                  module_name=module_name,
                  operation=operation,
                  execution_time=execution_time,
                  success=success,
                  error=error
              )

  - description: "Caching with TTL"
    language: python
    code: |
      from functools import lru_cache
      from datetime import datetime, timedelta
      from typing import Dict, Any, Optional
      
      
      class TimedCache:
          """Cache with TTL (Time To Live)"""
          
          def __init__(self, ttl_seconds: int = 3600):
              self.cache: Dict[str, tuple[Any, datetime]] = {}
              self.ttl = timedelta(seconds=ttl_seconds)
          
          def get(self, key: str) -> Optional[Any]:
              """Get value from cache if not expired"""
              if key in self.cache:
                  value, timestamp = self.cache[key]
                  if datetime.now() - timestamp < self.ttl:
                      return value
                  else:
                      del self.cache[key]
              return None
          
          def set(self, key: str, value: Any) -> None:
              """Set value in cache with current timestamp"""
              self.cache[key] = (value, datetime.now())
          
          def clear(self) -> None:
              """Clear all cache entries"""
              self.cache.clear()

  - description: "Lazy loading pattern"
    language: python
    code: |
      from typing import Optional
      from mavaia_core.brain.base_module import BaseBrainModule
      
      
      class LazyLoadModule(BaseBrainModule):
          """Module with lazy-loaded resources"""
          
          def __init__(self):
              self._model = None
              self._initialized = False
          
          def initialize(self) -> bool:
              """Lazy load model on initialization"""
              if not self._initialized:
                  try:
                      # Load expensive model here
                      self._model = self._load_model()
                      self._initialized = True
                      return True
                  except Exception as e:
                      logger.error(f"Failed to load model: {e}")
                      return False
              return True
          
          def _load_model(self):
              """Load expensive model (called only when needed)"""
              # Expensive model loading logic
              pass
          
          def execute(self, operation: str, params: dict[str, Any]) -> dict[str, Any]:
              """Execute operation (ensures model is loaded)"""
              if not self._initialized:
                  self.initialize()
              
              if not self._model:
                  raise RuntimeError("Model not loaded")
              
              # Use model for operation
              return self._perform_operation(operation, params)

