[Unit]
Description=Oricli MinIO Sovereign S3 Storage
After=docker.service network-online.target
Requires=docker.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/mike/Mavaia/docker/minio
ExecStart=/usr/bin/docker compose up -d --pull missing
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=120
TimeoutStopSec=30
User=mike

[Install]
WantedBy=multi-user.target
