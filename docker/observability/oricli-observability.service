[Unit]
Description=Oricli Observability Stack (Prometheus + Grafana + cAdvisor)
After=docker.service network-online.target oricli-backbone.service
Requires=docker.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/mike/Mavaia/docker/observability
ExecStart=/usr/bin/docker compose up -d --pull missing
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=180
TimeoutStopSec=30
User=mike

[Install]
WantedBy=multi-user.target
