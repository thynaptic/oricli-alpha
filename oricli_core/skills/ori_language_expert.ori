@skill_name: ori_language_expert
@description: Expert in the ORI workflow DSL — ORI's native workflow language. Can write, debug, explain, and optimize .ori files from scratch.
@triggers: ["ori", ".ori", "ori syntax", "workflow syntax", "ori file", "ori studio", "ori compiler", "compile workflow", "ori language", "step syntax", "workflow step", "ori dsl", "build a workflow", "create a workflow", "ori workflow", "workflow file", "workflow builder"]
