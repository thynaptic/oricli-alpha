{
  "concept_relations": {
    "hyponymy": {
      "description": "is a kind of",
      "examples": {
        "dog": ["animal", "pet", "mammal"],
        "car": ["vehicle", "automobile", "transportation"]
      },
      "reverse": "hypernymy"
    },
    "hypernymy": {
      "description": "is a general category for",
      "examples": {
        "animal": ["dog", "cat", "bird"],
        "vehicle": ["car", "truck", "bicycle"]
      },
      "reverse": "hyponymy"
    },
    "meronymy": {
      "description": "is a part of",
      "examples": {
        "wheel": ["car", "bicycle", "cart"],
        "branch": ["tree", "plant"]
      },
      "reverse": "holonymy"
    },
    "synonymy": {
      "description": "means the same as",
      "examples": {
        "happy": ["joyful", "glad", "pleased"],
        "big": ["large", "huge", "enormous"]
      }
    },
    "antonymy": {
      "description": "means the opposite of",
      "examples": {
        "happy": ["sad", "unhappy"],
        "hot": ["cold", "cool"]
      }
    },
    "causality": {
      "description": "causes",
      "examples": {
        "rain": ["wet", "umbrella", "indoors"],
        "fire": ["heat", "smoke", "danger"]
      }
    },
    "temporal": {
      "description": "happens before",
      "examples": {
        "morning": ["afternoon", "evening"],
        "spring": ["summer", "fall"]
      }
    }
  },
  "domains": {
    "scientific": {
      "concepts": ["physics", "chemistry", "biology", "mathematics"],
      "embeddings_model": "embedding_small"
    },
    "technical": {
      "concepts": ["programming", "software", "hardware", "technology"],
      "embeddings_model": "embedding_small"
    },
    "social": {
      "concepts": ["friendship", "relationship", "communication", "social"],
      "embeddings_model": "embedding_small"
    },
    "emotional": {
      "concepts": ["emotion", "feeling", "mood", "sentiment"],
      "embeddings_model": "embedding_small"
    },
    "abstract": {
      "concepts": ["idea", "concept", "theory", "principle"],
      "embeddings_model": "embedding_small"
    }
  },
  "similarity_thresholds": {
    "very_similar": 0.9,
    "similar": 0.7,
    "moderately_related": 0.5,
    "weakly_related": 0.3
  },
  "hierarchy_building": {
    "sibling_similarity_threshold": 0.7,
    "parent_child_similarity_threshold": 0.5,
    "max_hierarchy_depth": 10
  }
}

