{
  "max_history_length": 20,
  "reference_window": 5,
  "topic_continuity_threshold": 0.5,
  "entity_tracking": {
    "enabled": true,
    "max_entities": 50,
    "entity_decay": 0.9
  },
  "reference_patterns": {
    "immediate": {
      "patterns": ["that", "it", "this"],
      "turns_threshold": 1
    },
    "recent": {
      "patterns": ["that thing", "what we discussed", "earlier"],
      "turns_threshold": 3
    },
    "distant": {
      "patterns": ["as we talked about", "remember when", "you mentioned"],
      "turns_threshold": 5
    }
  },
  "topic_tracking": {
    "min_topic_length": 3,
    "topic_shift_threshold": 0.3,
    "topic_continuation_threshold": 0.5
  }
}

