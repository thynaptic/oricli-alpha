{
  "contraction_rules": {
    "formal": {
      "enabled": false,
      "probability": 0.0
    },
    "neutral": {
      "enabled": true,
      "probability": 0.6
    },
    "informal": {
      "enabled": true,
      "probability": 0.9
    }
  },
  "pronoun_patterns": {
    "use_you": true,
    "use_we": true,
    "natural_references": true,
    "collaborative_context": true
  },
  "naturalization_rules": {
    "formal_word_replacements": {
      "utilize": "use",
      "facilitate": "help",
      "implement": "do",
      "indicate": "show",
      "demonstrate": "show",
      "approximately": "about",
      "subsequent": "next",
      "prior to": "before",
      "in order to": "to",
      "with regard to": "about",
      "in the event that": "if"
    },
    "natural_openings": {
      "enabled": true,
      "probability": 0.3,
      "openings": [
        "Well,",
        "So,",
        "Actually,",
        "You know,",
        "I mean,",
        "Look,",
        "See,",
        "Right,"
      ]
    },
    "sentence_softening": {
      "enabled": true,
      "qualifiers": ["kind of", "sort of", "pretty much", "basically"]
    }
  },
  "human_touches": {
    "add_personality": true,
    "vary_structure": true,
    "natural_rhythm": true,
    "conversational_flow": true
  }
}

