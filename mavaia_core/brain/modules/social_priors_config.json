{
  "context_levels": {
    "formal": [
      "sir",
      "madam",
      "dear",
      "regards",
      "sincerely",
      "respectfully",
      "yours truly",
      "to whom it may concern",
      "i would like to",
      "i wish to",
      "permit me",
      "allow me"
    ],
    "informal": [
      "hey",
      "yo",
      "sup",
      "dude",
      "bro",
      "sis",
      "cuz",
      "lol",
      "omg",
      "haha",
      "yeah",
      "yep",
      "nope",
      "sure thing",
      "no problem",
      "no worries"
    ],
    "professional": [
      "please",
      "thank you",
      "appreciate",
      "would you",
      "could you",
      "i would appreciate",
      "i look forward to",
      "please let me know",
      "if you have any questions",
      "i'm here to help",
      "best regards"
    ],
    "casual": [
      "lol",
      "omg",
      "haha",
      "yeah",
      "sure",
      "totally",
      "awesome",
      "cool",
      "nice",
      "sweet",
      "rad",
      "lit",
      "fire",
      "bet",
      "no cap"
    ]
  },
  "appropriateness_rules": {
    "first_interaction": {
      "formality": "neutral_to_formal",
      "politeness": "high",
      "length": "medium",
      "markers_required": ["greeting", "acknowledgment"]
    },
    "returning_user": {
      "formality": "adapt_to_history",
      "politeness": "match_user",
      "length": "variable",
      "markers_required": []
    },
    "sensitive_topics": {
      "formality": "neutral_to_formal",
      "politeness": "very_high",
      "length": "longer",
      "markers_required": ["empathy", "acknowledgment"],
      "topics": ["health", "loss", "trauma", "mental_health", "financial_stress"]
    },
    "professional_context": {
      "formality": "formal",
      "politeness": "high",
      "length": "medium_to_long",
      "markers_required": ["professional_greeting", "professional_closing"]
    },
    "casual_context": {
      "formality": "informal",
      "politeness": "moderate",
      "length": "short_to_medium",
      "markers_required": []
    }
  },
  "relationship_dynamics": {
    "first_interaction": {
      "formality_baseline": 0.7,
      "personal_disclosure": 0.1,
      "humor_level": 0.2
    },
    "new_acquaintance": {
      "formality_baseline": 0.5,
      "personal_disclosure": 0.3,
      "humor_level": 0.4
    },
    "acquaintance": {
      "formality_baseline": 0.4,
      "personal_disclosure": 0.5,
      "humor_level": 0.6
    },
    "familiar": {
      "formality_baseline": 0.3,
      "personal_disclosure": 0.7,
      "humor_level": 0.7
    },
    "established": {
      "formality_baseline": 0.2,
      "personal_disclosure": 0.8,
      "humor_level": 0.8
    }
  },
  "cultural_sensitivity": {
    "inclusive_language": {
      "preferred": ["they/them", "everyone", "people", "folks", "individuals"],
      "avoid_gender_assumptions": true,
      "use_neutral_terms": true
    },
    "cultural_references": {
      "acknowledge_diversity": true,
      "avoid_stereotypes": true,
      "respect_cultural_differences": true
    },
    "regional_sensitivity": {
      "awareness_levels": {
        "high": ["health", "religion", "politics", "race", "gender"],
        "medium": ["food", "customs", "traditions"],
        "low": ["weather", "general_topics"]
      }
    }
  },
  "tone_adaptation_rules": {
    "formal_to_informal": {
      "add_contractions": true,
      "use_casual_greetings": true,
      "shorten_phrases": true,
      "add_casual_markers": true
    },
    "informal_to_formal": {
      "remove_contractions": true,
      "use_formal_greetings": true,
      "lengthen_phrases": true,
      "add_politeness_markers": true
    },
    "professional_adaptation": {
      "maintain_clarity": true,
      "use_precise_language": true,
      "include_professional_courtesies": true,
      "avoid_slang": true
    }
  },
  "context_detection": {
    "markers": {
      "crisis": ["help", "emergency", "urgent", "problem", "issue", "worried", "scared"],
      "celebration": ["congratulations", "happy", "excited", "great news", "awesome"],
      "support_needed": ["sad", "difficult", "hard", "struggling", "feeling", "need help"],
      "casual_chat": ["just", "thinking", "wondering", "curious", "what do you think"]
    }
  }
}

