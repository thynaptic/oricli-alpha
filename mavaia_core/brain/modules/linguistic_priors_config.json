{
  "syntax_patterns": {
    "question_types": ["wh", "yes_no", "tag", "imperative"],
    "sentence_types": ["declarative", "interrogative", "imperative", "exclamatory"],
    "common_structures": {
      "wh_questions": ["who", "what", "when", "where", "why", "how", "which"],
      "yes_no_starters": ["do", "does", "did", "is", "are", "was", "were", "can", "could", "will", "would", "should", "may", "might"],
      "imperative_verbs": ["go", "stop", "get", "make", "do", "let", "show", "tell", "give", "take", "put", "find", "help"]
    }
  },
  "semantics": {
    "word_sense_patterns": {
      "temporal": ["now", "then", "before", "after", "while", "during", "until", "since"],
      "spatial": ["here", "there", "where", "above", "below", "near", "far"],
      "causal": ["because", "since", "so", "therefore", "as a result"],
      "conditional": ["if", "unless", "provided that", "assuming"]
    },
    "concept_relations": {
      "hyponymy": "is a kind of",
      "meronymy": "is a part of",
      "synonymy": "means the same as",
      "antonymy": "means the opposite of"
    }
  },
  "pragmatics": {
    "politeness_markers": [
      "please",
      "could you",
      "would you",
      "if you don't mind",
      "i'd appreciate it if",
      "would it be possible",
      "i wonder if"
    ],
    "indirect_speech_acts": {
      "request": [
        "can you",
        "could you",
        "would you",
        "i need",
        "i want",
        "i'd like",
        "is it possible",
        "would it be possible"
      ],
      "suggestion": [
        "maybe",
        "perhaps",
        "how about",
        "what if",
        "i think",
        "you could",
        "why don't you",
        "have you considered"
      ],
      "complaint": [
        "i wish",
        "it would be nice if",
        "i'm not happy",
        "i'm frustrated",
        "this is annoying",
        "i don't like"
      ],
      "apology": [
        "sorry",
        "i apologize",
        "my apologies",
        "i'm sorry",
        "excuse me",
        "pardon me"
      ],
      "thanks": [
        "thank you",
        "thanks",
        "i appreciate",
        "much obliged",
        "grateful"
      ]
    },
    "implicature_triggers": {
      "quantity": ["a few", "some", "many", "all", "most"],
      "quality": ["i think", "i believe", "probably", "maybe", "perhaps"],
      "relation": ["by the way", "speaking of", "on that note"],
      "manner": ["frankly", "honestly", "to be honest", "to put it simply"]
    }
  },
  "discourse_markers": {
    "topic_transition": [
      "by the way",
      "speaking of",
      "on another note",
      "changing the subject",
      "while we're on the topic",
      "that reminds me"
    ],
    "agreement": [
      "right",
      "exactly",
      "i agree",
      "that's true",
      "absolutely",
      "definitely",
      "you're right",
      "that makes sense"
    ],
    "disagreement": [
      "actually",
      "i think",
      "but",
      "however",
      "on the other hand",
      "that's not quite right",
      "i disagree",
      "i'm not sure about that"
    ],
    "continuation": [
      "and",
      "also",
      "furthermore",
      "in addition",
      "moreover",
      "plus",
      "additionally",
      "what's more"
    ],
    "contrast": [
      "but",
      "however",
      "although",
      "though",
      "on the other hand",
      "in contrast",
      "whereas",
      "while"
    ],
    "conclusion": [
      "so",
      "therefore",
      "thus",
      "in conclusion",
      "to sum up",
      "in summary",
      "all in all",
      "overall"
    ],
    "exemplification": [
      "for example",
      "for instance",
      "such as",
      "like",
      "including",
      "namely"
    ]
  },
  "coherence_rules": {
    "pronoun_resolution": {
      "max_distance": 3,
      "allowed_pronouns": ["it", "this", "that", "they", "them", "he", "she", "we", "us"]
    },
    "topic_continuity": {
      "min_overlap_words": 2,
      "max_topic_shifts": 2
    },
    "turn_taking": {
      "max_overlap_length": 50,
      "min_turn_length": 5
    }
  }
}

