{
  "module": "reasoning_code_generator",
  "version": "1.0.0",
  "metadata": {
    "benchmark": "python_coding_benchmark",
    "notes": "Minimal starter benchmark to validate deterministic codegen + code execution harness."
  },
  "test_suite": [
    {
      "id": "code_001_add_function",
      "category": "functional",
      "module": "reasoning_code_generator",
      "operation": "generate_code_reasoning",
      "params": {
        "requirements": "Write a Python function add(a: int, b: int) -> int that returns a + b. Include type hints.",
        "reasoning_method": "cot"
      },
      "expected": {
        "validation": {
          "type": "code_execution",
          "test_cases": [
            {"input": {"a": 1, "b": 2}, "expected_output": 3},
            {"input": {"a": -1, "b": 5}, "expected_output": 4}
          ]
        }
      },
      "timeout": 30.0,
      "description": "Generate a simple function and validate it executes correctly",
      "tags": ["essential", "quick"]
    },
    {
      "id": "code_002_reverse_string",
      "category": "functional",
      "module": "reasoning_code_generator",
      "operation": "generate_code_reasoning",
      "params": {
        "requirements": "Write a Python function reverse_string(s: str) -> str that returns the reversed string.",
        "reasoning_method": "cot"
      },
      "expected": {
        "validation": {
          "type": "code_execution",
          "test_cases": [
            {"input": {"s": "hello"}, "expected_output": "olleh"},
            {"input": {"s": "mavaia"}, "expected_output": "aiviam"}
          ]
        }
      },
      "timeout": 30.0,
      "description": "Generate a string reversal function",
      "tags": ["essential"]
    }
  ]
}
