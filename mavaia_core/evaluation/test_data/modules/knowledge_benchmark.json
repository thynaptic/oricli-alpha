{
    "module": "cognitive_generator",
    "version": "1.0.0",
    "metadata": {
        "benchmark": "mavaia_internal_knowledge_bench",
        "description": "Mavaia internal benchmark for knowledge, reasoning, and instruction following.",
        "categories": [
            "science",
            "history",
            "logic",
            "coding",
            "format"
        ]
    },
    "test_suite": [
        {
            "id": "sci_001_physics",
            "category": "functional",
            "operation": "generate_response",
            "params": {
                "input": "Explain the concept of time dilation in special relativity in simple terms.",
                "persona": "mavaia"
            },
            "expected": {
                "result_type": "dict",
                "validation": {
                    "type": "contains_all",
                    "keywords": [
                        "time",
                        "dilation",
                        "speed",
                        "light",
                        "relative",
                        "slower"
                    ]
                }
            },
            "timeout": 60.0,
            "tags": [
                "knowledge",
                "science",
                "internal_benchmark"
            ]
        },
        {
            "id": "hist_001_general",
            "category": "functional",
            "operation": "generate_response",
            "params": {
                "input": "What were the primary causes of the fall of the Roman Empire?",
                "persona": "mavaia"
            },
            "expected": {
                "result_type": "dict",
                "validation": {
                    "type": "contains_any",
                    "keywords": [
                        "invasions",
                        "economic",
                        "political",
                        "military",
                        "lead",
                        "inflation"
                    ]
                }
            },
            "timeout": 60.0,
            "tags": [
                "knowledge",
                "history",
                "internal_benchmark"
            ]
        },
        {
