                    ]
                }
            },
            "timeout": 60.0,
            "tags": [
                "coding",
                "python",
                "internal_benchmark"
            ]
        },
        {
            "id": "format_001_json",
            "category": "functional",
            "operation": "generate_response",
            "params": {
                "input": "Generate a JSON object representing a book with title, author, and year. Output ONLY valid JSON.",
                "persona": "mavaia"
            },
            "expected": {
                "result_type": "dict",
                "validation": {
                    "type": "json_valid"
                }
            },
            "timeout": 60.0,
            "tags": [
                "instruction_following",
                "format",
                "internal_benchmark"
            ]
        },
        {
            "id": "dynamic_001_fallback",
            "category": "functional",
            "operation": "generate_response",
            "params": {
                "input": "How would you solve a problem that isn't in your knowledge base using autonomic execution and probabilistic routing?",
                "persona": "mavaia"
