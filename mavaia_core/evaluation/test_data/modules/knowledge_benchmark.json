            "operation": "generate_response",
            "params": {
                "input": "I have keys but no locks. I have a space but no room. You can enter, but never leave. What am I?",
                "persona": "mavaia"
            },
            "expected": {
                "result_type": "dict",
                "validation": {
                    "type": "contains",
                    "keyword": "keyboard"
                }
            },
            "timeout": 60.0,
            "tags": [
                "logic",
                "riddle",
                "internal_benchmark"
            ]
        },
        {
            "id": "code_001_python",
            "category": "functional",
            "operation": "generate_response",
            "params": {
                "input": "Write a Python function to calculate the Fibonacci sequence up to n terms.",
                "persona": "mavaia"
            },
            "expected": {
                "result_type": "dict",
                "validation": {
                    "type": "contains_all",
                    "keywords": [
                        "def",
